{
  // ==========================================
  // 继承配置
  // ==========================================

  // 继承 Node.js 22 的官方基础配置
  // 包含适合 Node.js 环境的编译选项
  "extends": "@tsconfig/node18/tsconfig.json",

  // ==========================================
  // 文件包含规则
  // ==========================================

  // 只包含 Node.js 环境的文件
  // 通常是构建配置文件
  "include": [
    "vite.config.ts", // Vite 配置文件
    "vitest.config.ts", // Vitest 配置文件(如果有)
    "*.config.ts", // 其他配置文件
    "*.config.*.ts", // 其他配置文件
    "*.conf.ts", // 其他配置文件
    "*.conf.*.ts", // 其他配置文件
    "scripts/**/*.ts" // 构建脚本(如果有)
  ],

  // ==========================================
  // 编译选项
  // ==========================================
  "compilerOptions": {
    // ------------------------------------------
    // 项目引用相关
    // ------------------------------------------

    // 启用项目引用
    "composite": true,

    // Node 环境的增量编译信息
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    // ------------------------------------------
    // 编译目标和模块系统
    // ------------------------------------------

    // Node.js 环境也可以用较新的 ES 版本
    // Node 14+ 支持大部分 ES2020 特性
    "target": "es2020",

    // 模块系统: ESNext
    // Node.js 14+ 支持 ES 模块(.mjs 或 package.json type:"module")
    "module": "esnext",

    // 类型定义库: 只需要 ES 特性,不需要 DOM
    "lib": ["ES2024"],

    // ------------------------------------------
    // 模块解析
    // ------------------------------------------

    // 使用 bundler 解析策略
    // 因为 Vite 配置文件也会被 Vite 处理
    "moduleResolution": "bundler",

    // 允许导入 .ts 扩展名
    "allowImportingTsExtensions": true,

    // 允许 CommonJS 模块的默认导入
    // 例如: import express from 'express'
    // 即使 express 使用 module.exports
    "allowSyntheticDefaultImports": true,

    // ------------------------------------------
    // 类型检查选项
    // ------------------------------------------

    // 启用严格模式
    "strict": true,

    // ------------------------------------------
    // 输出选项
    // ------------------------------------------

    // 不生成输出文件(Vite 会处理)
    "noEmit": true,

    // ------------------------------------------
    // 性能优化
    // ------------------------------------------

    // 跳过库文件的类型检查
    "skipLibCheck": true,

    // ------------------------------------------
    // Node.js 类型
    // ------------------------------------------

    // 引入 Node.js 类型定义
    "types": ["node"]
  }
}
