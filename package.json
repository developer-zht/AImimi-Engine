{
  "name": "refactored-games202-project",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": " sh ./scripts/copy-shaders.sh && vite build",
    "build:dev": "vite build --mode development",
    "build:staging": "vite build --mode staging",
    "build:analyze": "vite build --mode production -- --analyze",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{js,ts}",
    "lint:fix": "eslint src/**/*.js --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,json,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,json,css,html}\"",
    "check": "npm run type-check && npm run lint && npm run format:check",
    "fix": "npm run lint:fix && npm run format",
    "test": "vitest -c vitest.unit.config.ts",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest -c vitest.e2e.config.ts",
    "test:e2e:watch": "HEADLESS=false vitest -c vitest.e2e.config.ts --watch",
    "test:e2e:debug": "DEBUG=1 HEADLESS=false vitest -c vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky install",
    "commit": "cz"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": [
      "eslint --max-warnings 30",
      "prettier --check"
    ],
    "src/**/*.{json,css,html}": [
      "prettier --check"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@types/dat.gui": "^0.7.13",
    "core-js": "^3.45.1",
    "dat.gui": "^0.7.9",
    "dotenv": "^17.0.1",
    "gl-matrix": "^3.4.3",
    "imgui": "^1.0.10",
    "mathjs": "^14.7.0",
    "regenerator-runtime": "^0.14.1",
    "three": "^0.177.0",
    "url-join": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@html-eslint/eslint-plugin": "^0.52.1",
    "@types/gl": "^6.0.5",
    "@types/node": "^24.0.3",
    "@types/three": "^0.177.0",
    "@types/webgl2": "^0.0.11",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-markdown": "^5.1.0",
    "git-cz": "^4.9.0",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.1.5",
    "playwright": "^1.59.1",
    "prettier": "^3.6.2",
    "prettier-plugin-glsl": "^0.2.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "terser": "^5.43.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^6.3.5",
    "vitest": "4.1.5"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
