{
  // ==========================================
  // 继承配置
  // ==========================================

  // "extends": "",

  // ==========================================
  // 文件包含/排除规则
  // ==========================================

  // 指定要包含在编译中的文件
  "include": [
    "env.d.ts", // 环境变量类型声明
    "src/**/*" // src 目录下所有文件
  ],

  // 排除不需要编译的文件
  // 注意: 如果这些文件被 import,仍然会被类型检查
  "exclude": [
    "src/**/__tests__/**", // 测试目录
    "src/**/*.test.ts", // 单元测试文件
    "src/**/*.spec.ts", // 规格测试文件
    "node_modules" // 第三方依赖
  ],

  // ==========================================
  // 编译选项
  // ==========================================

  "compilerOptions": {
    // ------------------------------------------
    // 项目引用相关
    // ------------------------------------------

    // 启用复合项目模式，支持 Project References
    // 必须启用才能使用项目引用和增量编译
    "composite": true,

    // 增量编译信息文件的存储位置
    // 存储文件签名和时间戳,加速后续编译
    // 放在 node_modules/.tmp 中,不会污染源代码目录
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    // ------------------------------------------
    // 编译目标和模块系统
    // ------------------------------------------

    // 编译目标: es2020
    // 决定输出的 JavaScript 版本
    // 会转换 es2020 不支持的语法
    "target": "es2020",
    // 模块系统: es2020
    // 使用 es2020 模块语法 (import/export)
    // Vite 原生支持 ES 模块
    "module": "esnext",
    // 类型定义库: 告诉 TS 运行时有哪些 API 可用
    "lib": [
      "ES2024", // ES2020 的 JavaScript API(Promise, Array.from 等)
      "DOM", // DOM API(document, window, HTMLElement 等)
      "DOM.Iterable", // DOM 集合的迭代器(NodeList, HTMLCollection 等)
      "WebWorker"
    ],

    // ------------------------------------------
    // 模块解析
    // ------------------------------------------

    // 模块解析策略: bundler(Vite 推荐)
    // 专为打包工具设计,支持更灵活的导入
    "moduleResolution": "bundler",

    // 允许导入 .ts 扩展名
    // 因为 Vite 会在构建时处理它们
    "allowImportingTsExtensions": true,

    // 允许导入 JSON 文件
    // import data from './data.json'
    "resolveJsonModule": true,

    // 路径映射的基础目录(继承自根配置,也可以在这里覆盖)
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    // ------------------------------------------
    // 类型检查选项
    // ------------------------------------------

    // 启用所有严格类型检查选项
    // 包括: noImplicitAny, strictNullChecks 等
    "strict": true,

    // 检测未使用的局部变量
    "noUnusedLocals": true,

    // 检测未使用的参数
    "noUnusedParameters": true,

    // 检查 switch 语句是否有 fallthrough
    "noFallthroughCasesInSwitch": true,

    // ------------------------------------------
    // 输出选项
    // ------------------------------------------

    // 不生成输出文件
    // 因为 Vite 负责构建,TypeScript 只做类型检查
    "noEmit": true,

    // 生成 source map 文件(用于调试)
    "sourceMap": true,

    // ------------------------------------------
    // 互操作性
    // ------------------------------------------

    // 每个文件都是独立模块
    // esbuild 的要求,不支持跨文件的 const enum 等特性
    "isolatedModules": true,

    // 模块检测策略: force
    // 将所有文件都视为模块(即使没有 import/export)
    "moduleDetection": "force",

    // ------------------------------------------
    // 性能优化
    // ------------------------------------------

    // 跳过 .d.ts 文件的类型检查
    // 可以显著提升编译速度,因为第三方库的类型文件通常很大
    "skipLibCheck": true,

    // ------------------------------------------
    // 类型声明
    // ------------------------------------------

    // 引入的类型声明包
    // 只包含全局类型，其他通过 import 使用的库不需要写在这里
    // 这些会被添加到全局作用域
    "types": [
      // Vite 客户端类型(import.meta.env 等)
      // 注意: 这里应该是空数组或不包含这一项
      // 因为会在 env.d.ts 中通过 /// <reference types="vite/client" /> 引入
      "@types/webgl2"
    ]
  }
}
