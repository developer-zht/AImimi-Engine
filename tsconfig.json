{
  // ==========================================
  // 项目引用配置
  // ==========================================

  // files: [] 表示这个配置文件本身不直接编译任何文件
  // 所有文件的编译由 references 引用的子配置负责
  "files": [],
  // references: 引用其他 TypeScript 项目配置
  // 这实现了"项目引用"功能,让不同环境的代码使用不同的配置
  "references": [
    {
      "path": "./tsconfig.node.json" // Node.js 环境配置(构建工具等)
    },
    {
      "path": "./tsconfig.app.json" // 应用代码配置(浏览器环境)
    },
    {
      "path": "./tsconfig.vitest.json" // 测试代码配置(浏览器/node环境)
    }
  ],
  // ==========================================
  // 全局编译选项(所有子配置都会继承)
  // ==========================================
  "compilerOptions": {
    // 路径映射的基础目录
    // "." 表示 tsconfig.json 所在目录
    "baseUrl": ".",

    // 路径别名配置
    // 让 import '@/components/Button' 能正确解析
    "paths": {
      "@/*": ["./src/*"] // @ 映射到 src 目录
    }
  }
}
