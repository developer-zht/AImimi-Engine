{
  // 可以继承 app 配置,然后添加测试特定的选项
  "extends": "./tsconfig.app.json",

  // ==========================================
  // 文件包含规则
  // ==========================================

  // 只包含测试文件
  "include": [
    "src/**/*.test.ts", // 测试文件
    "src/**/*.spec.ts", // 规格测试文件
    "src/__tests__/*", // 测试目录
    "tests/**/*.ts" // 独立的测试目录(如果有)
  ],

  // ==========================================
  // 编译选项
  // ==========================================

  "compilerOptions": {
    // ------------------------------------------
    // 项目引用相关
    // ------------------------------------------

    // 启用项目引用
    "composite": true,

    // 测试环境的增量编译信息
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",

    // ------------------------------------------
    // 编译目标
    // ------------------------------------------

    // 测试在 Node.js 环境运行
    "target": "es2020",
    "module": "esnext",

    // 需要 DOM 类型(因为可能测试 Vue 组件)
    "lib": ["ES2024", "DOM", "DOM.Iterable"],

    // ------------------------------------------
    // 模块解析
    // ------------------------------------------

    "moduleResolution": "bundler",
    "resolveJsonModule": true,

    // ------------------------------------------
    // 输出选项
    // ------------------------------------------

    "noEmit": true,
    "isolatedModules": true,

    // ------------------------------------------
    // 类型检查(测试可以稍微宽松一些)
    // ------------------------------------------

    "strict": true,
    // 测试代码可能有未使用的变量(如 mock)
    // "noUnusedLocals": false,

    // ------------------------------------------
    // 测试框架类型
    // ------------------------------------------

    // 引入 Vitest 的全局类型
    // describe, it, expect, vi 等
    "types": [
      "vitest/globals", // Vitest 全局 API
      "node" // Node.js 类型
    ]
  }
}
